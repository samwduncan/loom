{
  "name": "@loom/mobile",
  "version": "3.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:dev": "REACT_NATIVE_PACKAGER_HOSTNAME=100.86.4.57 expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const src=p.resolve(__dirname,'node_modules/tailwindcss');const dst=p.resolve(__dirname,'..','node_modules/nativewind/node_modules/tailwindcss');if(!fs.existsSync(dst)){fs.mkdirSync(p.dirname(dst),{recursive:true});fs.cpSync(src,dst,{recursive:true});console.log('Nested tailwindcss v3 into nativewind')}\""
  },
  "dependencies": {
    "@loom/shared": "*",
    "@react-navigation/drawer": "^7.3.9",
    "@shopify/flash-list": "2.0.2",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-enriched-markdown": "^0.4.1",
