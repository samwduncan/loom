{
  "name": "@siteboon/claude-code-ui",
  "version": "1.21.0",
  "description": "A web-based UI for Claude Code CLI",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "claude-code-ui": "server/cli.js",
    "cloudcli": "server/cli.js"
  },
  "files": [
    "server/",
    "shared/",
    "dist/",
    "scripts/",
    "README.md"
  ],
  "homepage": "https://cloudcli.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siteboon/claudecodeui.git"
  },
  "bugs": {
    "url": "https://github.com/siteboon/claudecodeui/issues"
  },
  "scripts": {
    "dev": "node server/index.js",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "release": "./release.sh",
    "postinstall": "node scripts/fix-node-pty.js",
    "prepare": "husky",
    "test:shared": "cd shared && npx vitest run",
    "test:web": "cd src && npx vitest run",
    "build:web": "cd src && npm run build"
  },
  "keywords": [
    "claude code",
    "ai",
    "anthropic",
    "ui",
    "mobile"
